# LLM API Keys
DEEPSEEK_API_KEY=

# Embedding API Keys (Optional Fallback)
# By default, AetherDocs uses a local SentenceTransformer model ("all-MiniLM-L6-v2") for zero-dependency embeddings.
# If SentenceTransformers is unavailable, it falls back to OpenAI's remote API ("text-embedding-3-small").
# Provide your OpenAI API key and optionally a custom base URL to configure this remote fallback.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# LangChain / LangSmith Tracing (Optional)
# If you want to enable LangChain tracing to debug and monitor the LangGraph pipeline, set these keys:
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=aether_docs
